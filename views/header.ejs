<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>
        <%= title %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="/css/style.css" rel="stylesheet" />
    <style>
        body {
            background-color: #f8f9fa;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .card {
            transition: transform 0.2s, box-shadow 0.2s;
            border: none;
        }

        .card:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.08) !important;
        }

        .navbar .dropdown-menu {
            border: none;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
            border-radius: 12px;
            margin-top: 10px;
        }

        .navbar .dropdown-item {
            padding: 10px 20px;
            font-size: 0.95rem;
            display: flex;
            align-items: center;
        }

        .navbar .dropdown-item i {
            margin-right: 12px;
            font-size: 1.1rem;
        }

        .container-fluid {
            max-width: 1600px;
            margin: 0 auto;
        }
    </style>
</head>

<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
        <div class="container-fluid px-4">
            <a class="navbar-brand fw-bold text-uppercase tracking-wider" href="/">
                <i class="bi bi-trophy-fill text-warning me-2"></i>Vé Bóng Đá Online
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link active" href="/">Trang chủ</a>
                    </li>
                </ul>

                <div class="d-flex align-items-center">
                    <% if (session && session.MaNguoiDung) { %>
                        <div class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center text-white" href="#" role="button"
                                data-bs-toggle="dropdown" aria-expanded="false">
                                <img src="<%= session.Avatar || 'https://cdn-icons-png.flaticon.com/512/149/149071.png' %>" alt="User" width="32"
                                    height="32" class="rounded-circle border border-2 border-light me-2" style="object-fit: cover;">
                                <span class="small">Chào, <strong> <%= session.HoVaTen %></strong></span>
                            </a>

                            <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0">
                                <% if (session.QuyenHan !=='admin' ) { %>
                                    <li class="px-3 py-2 bg-light rounded-top">
                                        <div class="text-muted small text-uppercase fw-bold">Số dư ví</div>
                                        <div class="text-success fw-bold fs-5">
                                            <%= session.SoDu ? session.SoDu.toLocaleString('vi-VN') : 0 %>đ
                                        </div>
                                    </li>
                                    <li>
                                        <hr class="dropdown-divider">
                                    </li>
                                    <li>
                                        <a class="dropdown-item" href="/nguoidung/kho-ve"><i class="bi bi-ticket-perforated text-primary"></i>Vé của tôi</a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" href="/nguoidung/profile"><i class="bi bi-person-badge text-info"></i>Thông tin tài khoản</a>
                                    </li>
                                    <li>
                                        <hr class="dropdown-divider">
                                    </li>
                                    <li>
                                        <a class="dropdown-item" href="/naptien"><i class="bi bi-wallet2 text-success"></i>Nạp tiền vào ví</a>
                                    </li>
                                <% } %>

                                <% if (session.QuyenHan==='admin' ) { %>
                                    <li>
                                        <a class="dropdown-item fw-bold text-danger" href="/admin"><i class="bi bi-speedometer2"></i>Trang Quản Trị</a>
                                    </li>
                                    <li>
                                        <hr class="dropdown-divider">
                                    </li>
                                <% } %>

                                    <li>
                                        <a class="dropdown-item" href="/auth/doimatkhau"><i class="bi bi-shield-lock text-warning"></i>Đổi mật khẩu</a>
                                    </li>
                                    <li>
                                        <hr class="dropdown-divider">
                                    </li>
                                        <li><a class="dropdown-item text-danger" href="/auth/dangxuat"><i class="bi bi-box-arrow-right"></i>Đăng xuất</a>
                                    </li>
                            </ul>
                        </div>

                        <% } else { %>
                            <div class="d-flex gap-2 shadow-sm">
                                <a href="/auth/dangnhap" class="btn btn-outline-light btn-sm px-3 rounded-pill">Đăng nhập</a>
                                <a href="/auth/dangky" class="btn btn-primary btn-sm px-3 rounded-pill">Đăng ký</a>
                            </div>
                        <% } %>
                </div>
            </div>
        </div>
    </nav>

    <div class="container-fluid px-4 mt-4 mb-5 flex-grow-1">