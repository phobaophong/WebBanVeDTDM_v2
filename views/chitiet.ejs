<%- include('header') %>

<style>
    .match-header {
        background: linear-gradient(rgba(13, 33, 55, 0.85), rgba(13, 33, 55, 0.95)), url('https://www.transparenttextures.com/patterns/stardust.png');
        background-color: #0b1a2a;
        color: white;
        border-radius: 1rem;
        padding: 3rem 0;
        margin-bottom: 2rem;
    }
    .big-logo {
        width: 120px;
        height: 120px;
        object-fit: contain;
        background: white;
        padding: 10px;
        border-radius: 50%;
        border: 4px solid #fff;
        box-shadow: 0 10px 20px rgba(0,0,0,0.2);
    }
    .vs-text {
        font-size: 2.5rem;
        font-weight: 900;
        color: #ffc107;
        text-shadow: 0 4px 10px rgba(0,0,0,0.3);
    }
    .ticket-card {
        transition: 0.2s;
        border: 2px solid transparent;
    }
    .ticket-card:hover {
        border-color: #0d6efd;
        background-color: #f8f9fa;
    }
    .ticket-radio:checked + .ticket-card {
        border-color: #198754;
        background-color: #f0fdf4;
        box-shadow: 0 4px 15px rgba(25, 135, 84, 0.15);
    }
</style>

<div class="match-header shadow">
    <div class="container text-center">
        <span class="badge bg-primary rounded-pill px-3 py-2 mb-3 fs-6"><%= td.GiaiDau %> - <%= td.VongDau %></span>
        
        <div class="row align-items-center justify-content-center mb-4">
            <div class="col-4 col-md-3 text-end">
                <img src="<%= td.LogoNha || 'https://cdn-icons-png.flaticon.com/512/534/534125.png' %>" class="big-logo mb-2">
                <h3 class="fw-bold m-0"><%= td.DoiNha %></h3>
            </div>
            <div class="col-2 col-md-2 text-center">
                <div class="vs-text mb-2">VS</div>
                <% if(td.Hot) { %> <span class="badge bg-danger animate-pulse px-3 py-2 rounded-pill shadow">🔥 TRẬN CẦU TÂM ĐIỂM</span> <% } %>
            </div>
            <div class="col-4 col-md-3 text-start">
                <img src="<%= td.LogoKhach || 'https://cdn-icons-png.flaticon.com/512/534/534125.png' %>" class="big-logo mb-2">
                <h3 class="fw-bold m-0"><%= td.DoiKhach %></h3>
            </div>
        </div>

        <div class="d-inline-flex gap-4 opacity-75">
            <span><i class="bi bi-clock-history text-warning me-1"></i> <%= new Date(td.ThoiGian).toLocaleString('vi-VN', {hour: '2-digit', minute:'2-digit', day: '2-digit', month: '2-digit', year: 'numeric'}) %></span>
            <span><i class="bi bi-geo-alt-fill text-danger me-1"></i> Sân vận động <%= td.SanVanDong %></span>
        </div>
    </div>
</div>

<div class="row justify-content-center mb-5">
    <div class="col-lg-8">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-header bg-white border-bottom py-3">
                <h5 class="fw-bold m-0 text-primary"><i class="bi bi-ticket-perforated-fill me-2"></i>Chọn Hạng Vé</h5>
            </div>
            <div class="card-body p-4">
                
                <% if (td.HangVe.length === 0 || td.TrangThai !== 'Sắp diễn ra') { %>
                    <div class="text-center py-5">
                        <i class="bi bi-lock-fill display-1 text-muted opacity-25"></i>
                        <h4 class="mt-3 text-muted">Trận đấu này hiện chưa mở bán vé!</h4>
                        <a href="/" class="btn btn-outline-primary rounded-pill mt-2">Quay lại trang chủ</a>
                    </div>
                <% } else { %>
                    <form action="/donhang/thanhtoan" method="POST">
                        <input type="hidden" name="MaTranDau" value="<%= td._id %>">

                        <div class="row g-3 mb-4">
                            <% td.HangVe.forEach((ve, index) => { %>
                                <div class="col-md-6">
                                    <label class="w-100 cursor-pointer" style="cursor: pointer;">
                                        <input type="radio" name="TenHangVe" value="<%= ve.TenHang %>" class="d-none ticket-radio" <%= index === 0 ? 'checked' : '' %> <%= ve.SoLuongCon <= 0 ? 'disabled' : '' %>>
                                        
                                        <div class="card ticket-card rounded-3 h-100 <%= ve.SoLuongCon <= 0 ? 'bg-light opacity-50' : '' %>">
                                            <div class="card-body">
                                                <div class="d-flex justify-content-between align-items-start mb-2">
                                                    <h6 class="fw-bold m-0 <%= ve.TenHang.includes('VIP') ? 'text-warning' : 'text-dark' %>">
                                                        <%= ve.TenHang %>
                                                    </h6>
                                                    <% if (ve.SoLuongCon <= 0) { %>
                                                        <span class="badge bg-secondary">Hết vé</span>
                                                    <% } else if (ve.SoLuongCon < 20) { %>
                                                        <span class="badge bg-danger">Chỉ còn <%= ve.SoLuongCon %></span>
                                                    <% } else { %>
                                                        <span class="badge bg-success">Còn trống</span>
                                                    <% } %>
                                                </div>
                                                <h5 class="text-primary fw-bold mb-0"><%= ve.GiaTien.toLocaleString('vi-VN') %>đ</h5>
                                            </div>
                                        </div>
                                    </label>
                                </div>
                            <% }) %>
                        </div>

                        <div class="bg-light p-3 rounded-3 border mb-4 d-flex align-items-center justify-content-between">
                            <h6 class="fw-bold m-0 text-secondary">Số lượng mua:</h6>
                            <div class="d-flex align-items-center" style="width: 150px;">
                                <input type="number" name="SoLuongMua" class="form-control text-center fw-bold border-primary" value="1" min="1" max="5" required>
                            </div>
                        </div>

                        <% if(session && session.MaNguoiDung) { %>
                            
                            <% if(session.QuyenHan === 'admin') { %>
                                <button type="button" class="btn btn-secondary btn-lg w-100 rounded-pill fw-bold shadow-sm cursor-not-allowed" disabled>
                                    <i class="bi bi-shield-lock-fill me-2"></i> TÀI KHOẢN QUẢN TRỊ KHÔNG THỂ ĐẶT VÉ
                                </button>
                                <div class="text-center mt-2 small text-danger">
                                    * Quản trị viên chỉ có quyền quản lý, vui lòng dùng tài khoản khách hàng để mua vé.
                                </div>
                            <% } else { %>
                                <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill fw-bold shadow-sm">
                                    <i class="bi bi-cart-check-fill me-2"></i> TIẾP TỤC THANH TOÁN
                                </button>
                                <div class="text-center mt-2 small text-muted">
                                    * Mỗi khách hàng được mua tối đa 5 vé.
                                </div>
                            <% } %>

                        <% } else { %>
                            <a href="/auth/dangnhap" class="btn btn-warning btn-lg w-100 rounded-pill fw-bold shadow-sm">
                                <i class="bi bi-box-arrow-in-right me-2"></i> VUI LÒNG ĐĂNG NHẬP ĐỂ MUA VÉ
                            </a>
                        <% } %>

                    </form>
                <% } %>

            </div>
        </div>
    </div>
</div>

<%- include('footer') %>