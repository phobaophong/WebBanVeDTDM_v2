<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8">
    <title>
        <%= title %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #f4f6f9;
            font-family: Arial, sans-serif;
        }

        /* Tùy chỉnh thanh Sidebar bên trái */
        .sidebar {
            min-height: 100vh;
            width: 260px;
            background-color: #343a40;
            transition: all 0.3s;
        }

        .sidebar a {
            color: #c2c7d0;
            text-decoration: none;
            padding: 15px 20px;
            display: block;
            border-left: 4px solid transparent;
            font-weight: 500;

            transition: all 0.25s ease;
        }

        .sidebar a:hover,
        .sidebar a.active {
            background-color: #495057;
            color: #fff;
            border-left-color: #0d6efd;
            padding-left: 25px;
        }

        .main-content {
            flex-grow: 1;
            min-width: 0;
        }
    </style>
</head>

<body class="d-flex">
    <!-- menu bên trái -->
    <div class="sidebar d-flex flex-column shadow">
        <div class="text-center py-4 border-bottom border-secondary">
            <h5 class="text-white fw-bold mb-0"><i class="bi bi-shield-lock-fill text-warning"></i> MENU ADMIN </h5>
        </div>
        <div class="flex-grow-1 pt-3">
            <a href="/admin"><i class="bi bi-speedometer2 me-2"></i> Bảng điều khiển</a>
            <a href="/admin/themtran"><i class="bi bi-trophy me-2"></i> Quản lý Trận đấu</a>
            <a href="/admin/taove"><i class="bi bi-magic me-2"></i> Quản lý Tạo vé</a>
            <a href="/admin/donhang"><i class="bi bi-receipt me-2"></i> Quản lý Đơn hàng</a>
            <a href="/admin/nguoidung"><i class="bi bi-people me-2"></i> Quản lý Người dùng</a>
            <a href="/admin/quetve"><i class="bi bi-upc-scan me-2 text-warning"></i> Soát Vé Tại Cổng</a>
        </div>
        <div class="p-3 border-top border-secondary">
            <a href="/" class="btn btn-outline-light w-100 btn-sm"><i class="bi bi-box-arrow-left"></i> Về trang web</a>
        </div>
    </div>

    <div class="main-content d-flex flex-column">
        <nav class="navbar navbar-light bg-white shadow-sm px-4 py-3 mb-4">
            <span class="navbar-brand mb-0 h5 fw-bold text-primary text-uppercase">
                <%= title %>
            </span>
            <div class="d-flex align-items-center">
                <% if(session && session.HoVaTen) { %>
                    <span class="me-3 small text-secondary">Chào sếp, <strong>
                            <%= session.HoVaTen %>
                        </strong></span>
                    <% } %>
                        <a href="/auth/dangxuat" class="btn btn-sm btn-danger"><i class="bi bi-power"></i> Đăng xuất</a>
            </div>
        </nav>
        <script>
            document.addEventListener("DOMContentLoaded", function() {
                let currentPath = window.location.pathname;
                
                let sidebarLinks = document.querySelectorAll('.sidebar a');

                sidebarLinks.forEach(link => {
                    let href = link.getAttribute('href');
                    
                    if (href !== '/' && (currentPath === href || (href !== '/admin' && currentPath.startsWith(href)))) {
                        link.classList.add('active');
                    }
                });
            });
        </script>
        <div class="container-fluid px-4">
            <%- message %>