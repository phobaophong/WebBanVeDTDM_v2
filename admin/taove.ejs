<%- include('header') %>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold text-primary mb-0"><i class="bi bi-ticket-detailed me-2"></i>Tạo vé cho cho các trận đấu</h4>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-dark text-white fw-bold py-3">
                    <i class="bi bi-funnel-fill me-2"></i>1. Chọn Giải Đấu
                </div>
                <div class="card-body bg-light">
                    <form action="/admin/taove" method="GET">
                        <label class="form-label fw-bold small text-secondary">Lọc danh sách trận đấu:</label>
                        <select name="giaidau" class="form-select border-primary mb-3 shadow-sm"
                            onchange="this.form.submit()">
                            <option value="">-- Vui lòng chọn giải đấu --</option>
                            <% danhSachGiaiDau.forEach(giai=> { %>
                                <option value="<%= giai %>" <%=giaidauDaChon===giai ? 'selected' : '' %>><%= giai %>
                                </option>
                                <% }) %>
                        </select>
                    </form>

                    <% if (giaidauDaChon) { %>
                        <hr>
                        <div class="alert alert-warning small p-2 text-center mb-3">
                            Vé tự động sẽ được tạo = <strong>30%</strong> Sức chứa sân. (Gồm 5 hạng ghế).
                        </div>
                        <a href="/admin/taove-hangloat?giaidau=<%= giaidauDaChon %>"
                            class="btn btn-success w-100 fw-bold shadow-sm py-2">
                            <i class="bi bi-magic me-1"></i> TẠO VÉ HÀNG LOẠT CHO GIẢI NÀY
                        </a>
                        <% } %>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow-sm border-0 rounded-3 h-100">
                <div class="card-header bg-primary text-white fw-bold py-3 d-flex justify-content-between">
                    <span><i class="bi bi-list-task me-2"></i>2. Trạng thái phân bổ vé</span>
                    <% if (giaidauDaChon) { %>
                        <span class="badge bg-light text-primary">
                            <%= trandauDb.length %> Trận
                        </span>
                        <% } %>
                </div>
                <div class="card-body bg-light p-0">
                    <% if (!giaidauDaChon) { %>
                        <div class="text-center py-5 text-muted">
                            <i class="bi bi-arrow-left-circle fs-1 mb-3 d-block opacity-50"></i>
                            <h5>Vui lòng chọn giải đấu để tiếp tục</h5>
                        </div>
                        <% } else if (trandauDb.length===0) { %>
                            <div class="text-center py-5 text-muted">
                                <h5>Chưa có dữ liệu nào của giải <%= giaidauDaChon %>
                                </h5>
                            </div>
                            <% } else { %>
                                <div class="table-responsive" style="max-height: 600px; overflow-y: auto;">
                                    <table class="table table-hover table-striped mb-0 text-center align-middle">
                                        <thead class="table-dark sticky-top">
                                            <tr>
                                                <th>Vòng</th>
                                                <th>Trận đấu</th>
                                                <th>Sân / Sức chứa</th>
                                                <th>Thao tác</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% trandauDb.forEach(td=> { %>
                                                <tr>
                                                    <td><span class="badge bg-secondary">
                                                            <%= td.VongDau %>
                                                        </span></td>
                                                    <td class="small">
                                                        <div
                                                            class="fw-bold d-flex justify-content-center align-items-center">
                                                            <% if(td.LogoNha) { %> <img src="<%= td.LogoNha %>"
                                                                    height="16" class="me-1">
                                                                <% } %>
                                                                    <%= td.DoiNha %> <span
                                                                            class="mx-1 text-muted">-</span>
                                                                        <%= td.DoiKhach %>
                                                                            <% if(td.LogoKhach) { %> <img
                                                                                    src="<%= td.LogoKhach %>"
                                                                                    height="16" class="ms-1">
                                                                                <% } %>
                                                        </div>
                                                        <div class="text-muted mt-1" style="font-size: 0.75rem;">
                                                            <%= new Date(td.ThoiGian).toLocaleString('vi-VN') %>
                                                        </div>
                                                    </td>
                                                    <td class="small">
                                                        <div class="fw-bold">
                                                            <%= td.SanVanDong %>
                                                        </div>
                                                        <span class="text-muted">
                                                            <%= td.SucChua.toLocaleString('vi-VN') %> chỗ
                                                        </span>
                                                    </td>
                                                    <td>
                                                        <% if (td.TrangThai !=='Sắp diễn ra' ) { %>
                                                            <span class="badge bg-secondary opacity-50 shadow-sm"><i
                                                                    class="bi bi-lock-fill"></i> Đã khóa sổ</span>
                                                            <% } else if (td.HangVe.length===0) { %>
                                                                <div class="d-flex gap-2 justify-content-center">
                                                                    <a href="/admin/taovenhanh/<%= td._id %>?giaidau=<%= giaidauDaChon %>"
                                                                        class="btn btn-outline-success btn-sm fw-bold shadow-sm"
                                                                        title="Hệ thống tự chia vé">
                                                                        <i class="bi bi-lightning-charge-fill"></i>
                                                                        Nhanh
                                                                    </a>

                                                                    <button
                                                                        class="btn btn-outline-warning btn-sm fw-bold shadow-sm"
                                                                        data-bs-toggle="modal"
                                                                        data-bs-target="#modalVe-<%= td._id %>"
                                                                        title="Tự nhập giá & số lượng">
                                                                        <i class="bi bi-pencil-square"></i> Chỉnh tay
                                                                    </button>
                                                                </div>

                                                                <div class="modal fade text-start"
                                                                    id="modalVe-<%= td._id %>" tabindex="-1">
                                                                    <div class="modal-dialog">
                                                                        <form
                                                                            action="/admin/taove-thucong/<%= td._id %>?giaidau=<%= giaidauDaChon %>"
                                                                            method="POST" class="modal-content">
                                                                            <div class="modal-header bg-warning">
                                                                                <h6
                                                                                    class="modal-title fw-bold text-dark">
                                                                                    <i
                                                                                        class="bi bi-gear-fill me-2"></i>Cài
                                                                                    đặt vé: <%= td.DoiNha %> vs <%=
                                                                                            td.DoiKhach %>
                                                                                </h6>
                                                                                <button type="button" class="btn-close"
                                                                                    data-bs-dismiss="modal"></button>
                                                                            </div>
                                                                            <div class="modal-body bg-light">
                                                                                <p
                                                                                    class="small text-danger fw-bold mb-3">
                                                                                    * Sức chứa tối đa của sân: <%=
                                                                                        td.SucChua.toLocaleString('vi-VN')
                                                                                        %> người.</p>

                                                                                <div class="row g-3">
                                                                                    <div class="col-6">
                                                                                        <label class="form-label small fw-bold text-secondary">Giá
                                                                                            VIP</label>
                                                                                        <input type="number" name="giaVIP" class="form-control" value="5000000" required>
                                                                                    </div>
                                                                                    <div class="col-6">
                                                                                        <label class="form-label small fw-bold text-secondary">Số
                                                                                            lượng VIP</label>
                                                                                        <input type="number" name="slVIP" class="form-control" value="50" required>
                                                                                    </div>
                                                                                    
                                                                                    <div class="col-6">
                                                                                        <label class="form-label small fw-bold text-secondary">Giá
                                                                                            Khán đài A</label>
                                                                                        <input type="number" name="giaA" class="form-control" value="3000000" required>
                                                                                    </div>
                                                                                    <div class="col-6">
                                                                                        <label class="form-label small fw-bold text-secondary">Số
                                                                                            lượng Khán đài A</label>
                                                                                        <input type="number" name="slA" class="form-control" value="200" required>
                                                                                    </div>
                                                                                    
                                                                                    <div class="col-6">
                                                                                        <label class="form-label small fw-bold text-secondary">Giá
                                                                                            Khán đài B</label>
                                                                                        <input type="number" name="giaB" class="form-control" value="1500000" required>
                                                                                    </div>
                                                                                    <div class="col-6">
                                                                                        <label class="form-label small fw-bold text-secondary">Số
                                                                                            lượng Khán đài B</label>
                                                                                        <input type="number" name="slB" class="form-control" value="300" required>
                                                                                    </div>
                                                                                    <div class="col-6">
                                                                                        <label class="form-label small fw-bold text-secondary">Giá Khán đài C</label>
                                                                                        <input type="number" name="giaC" class="form-control" value="1000000" required>
                                                                                    </div>
                                                                                    <div class="col-6">
                                                                                        <label class="form-label small fw-bold text-secondary">Số lượng Khán đài C</label>
                                                                                        <input type="number" name="slC" class="form-control" value="400" required>
                                                                                    </div>
                                                                                    
                                                                                    <div class="col-6">
                                                                                        <label class="form-label small fw-bold text-secondary">Giá Khán đài D</label>
                                                                                        <input type="number" name="giaD" class="form-control" value="800000" required>
                                                                                    </div>
                                                                                    <div class="col-6">
                                                                                        <label class="form-label small fw-bold text-secondary">Số lượng Khán đài D</label>
                                                                                        <input type="number" name="slD" class="form-control" value="400" required>
                                                                                    </div>
                                                                                </div>
                                                                            </div>
                                                                            <div class="modal-footer bg-white">
                                                                                <button type="button"
                                                                                    class="btn btn-secondary btn-sm"
                                                                                    data-bs-dismiss="modal">Hủy</button>
                                                                                <button type="submit"
                                                                                    class="btn btn-primary btn-sm fw-bold"><i
                                                                                        class="bi bi-floppy2-fill me-2"></i>Lưu
                                                                                    Mức Giá</button>
                                                                            </div>
                                                                        </form>
                                                                    </div>
                                                                </div>
                                                                <% } else { %>
                                                                    <% var tongVe=0; td.HangVe.forEach(v=> tongVe +=
                                                                        v.SoLuong);
                                                                        %>
                                                                        <span class="badge bg-success shadow-sm">Đang mở
                                                                            bán</span>
                                                                        <div class="text-secondary mt-1 fw-bold"
                                                                            style="font-size: 0.75rem;">
                                                                            <%= tongVe.toLocaleString('vi-VN') %> vé
                                                                        </div>
                                                                        <% } %>
                                                    </td>
                                                </tr>
                                                <% }) %>
                                        </tbody>
                                    </table>
                                </div>
                                <% } %>
                </div>
            </div>
        </div>
    </div>

    <%- include('footer') %>